# Required: your Basecamp account ID
# Find it with: basecamp accounts list --json
BASECAMP_ACCOUNT_ID=6198238

# Optional: "true" to disable all write tools (create/update/complete/post), "false" to enable writes
# Useful for read-only integrations or auditing. Default: false (writes enabled)
BASECAMP_READONLY=true

# Optional: HTTP port the MCP server listens on (web mode only). Default: 3333
PORT=3333
